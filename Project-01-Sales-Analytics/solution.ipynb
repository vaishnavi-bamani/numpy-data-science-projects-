   "source": [
    "# Load the sales dataset from CSV file\n",
    "sales_data = np.genfromtxt(\n",
    "    \"dataset/sales.csv\",\n",
    "    delimiter=\",\",\n",
    "    skip_header=1\n",
    ")\n",
    "\n",
    "# Extract day numbers and sales\n",
    "days = sales_data[:, 0]\n",
    "sales = sales_data[:, 1]\n",
    "\n",
    "print(f\"Dataset Shape: {sales_data.shape}\")\n",
    "print(f\"Data Type: {sales_data.dtype}\")\n",
    "print(\"\\nRaw Dataset:\")\n",
    "print(sales_data)"
   ]
