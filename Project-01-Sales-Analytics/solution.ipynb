   "source": [
    "# Create sales trend visualization\n",
    "fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(14, 10))\n",
    "\n",
    "# Plot 1: Sales Trend\n",
    "ax1.plot(days, sales, marker='o', linewidth=2.5, markersize=7, color='#2E86AB', label='Daily Sales')\n",
    "ax1.axhline(y=average_sales, color='#A23B72', linestyle='--', linewidth=2, label=f'Average (₹{average_sales:,.0f})')\n",
    "ax1.fill_between(days, sales, average_sales, where=(sales >= average_sales), alpha=0.2, color='green', label='Above Average')\n",
    "ax1.fill_between(days, sales, average_sales, where=(sales < average_sales), alpha=0.2, color='red', label='Below Average')\n",
    "ax1.set_xlabel('Day', fontsize=12, fontweight='bold')\n",
    "ax1.set_ylabel('Sales (₹)', fontsize=12, fontweight='bold')\n",
    "ax1.set_title('30-Day Sales Trend Analysis', fontsize=14, fontweight='bold')\n",
    "ax1.legend(loc='upper left', fontsize=10)\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# Plot 2: Daily Growth Rate\n",
    "daily_growth = np.diff(sales)\n",
    "growth_days = days[:-1]\n",
