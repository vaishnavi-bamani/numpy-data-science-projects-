   ],
   "source": [
    "# Calculate key metrics\n",
    "total_revenue = np.sum(sales)\n",
    "average_sales = np.mean(sales)\n",
    "median_sales = np.median(sales)\n",
    "std_dev = np.std(sales)\n",
    "highest_sales = np.max(sales)\n",
    "lowest_sales = np.min(sales)\n",
    "highest_index = np.argmax(sales)\n",
    "lowest_index = np.argmin(sales)\n",
    "sales_range = highest_sales - lowest_sales\n",
    "coefficient_variation = (std_dev / average_sales) * 100\n",
    "\n",
    "# Display metrics\n",
    "print(\"========== SALES METRICS SUMMARY ==========\")\n",
    "print(f\"✓ Total Revenue          : ₹{total_revenue:,.2f}\")\n",
    "print(f\"✓ Average Daily Sales    : ₹{average_sales:,.2f}\")\n",
    "print(f\"✓ Median Sales           : ₹{median_sales:,.2f}\")\n",
    "print(f\"✓ Standard Deviation     : ₹{std_dev:,.2f}\")\n",
    "print(f\"✓ Coefficient of Variation: {coefficient_variation:.2f}%\")\n",
    "print(f\"✓ Sales Range            : ₹{sales_range:,.2f} (₹{lowest_sales:,.0f} - ₹{highest_sales:,.0f})\")\n",
    "print(\"=\"*44)"
   ]
  },
