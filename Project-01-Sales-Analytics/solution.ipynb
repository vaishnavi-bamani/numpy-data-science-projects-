    "---\n",
    "\n",
    "# 📈 Key Performance Indicators (KPIs)\n",
    "\n",
    "## Core Sales Metrics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "kpi-analysis",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "========== SALES METRICS SUMMARY ==========\n",
      "✓ Total Revenue          : ₹91,200.00\n",
      "✓ Average Daily Sales    : ₹3,040.00\n",
