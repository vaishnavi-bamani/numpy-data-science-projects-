    "## 📉 Task 6: Sales Growth Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "38c42c20",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "========== SALES GROWTH ANALYSIS ==========\n",
      "Days with Increased Sales : 21 out of 29 (72.41%)\n",
      "Days with Decreased Sales : 8  out of 29 (27.59%)\n",
      "Days with No Change       : 0  out of 29 (0.00%)\n",
      "Average Growth (positive) : ₹200.95\n",
      "Average Decline (negative): ₹-162.50\n",
      "Net Growth Trend          : ✅ POSITIVE (2.69x more growth days)\n",
      "=========================================\n"
     ]
    }
   ],
   "source": [
    "# Sales Growth Analysis\n",
    "daily_growth = np.diff(sales)\n",
    "\n",
    "increase_days = np.sum(daily_growth > 0)\n",
    "decrease_days = np.sum(daily_growth < 0)\n",
    "no_change_days = np.sum(daily_growth == 0)\n",
    "avg_growth = np.mean(daily_growth[daily_growth > 0])\n",
    "avg_decline = np.mean(daily_growth[daily_growth < 0])\n",
    "growth_ratio = increase_days / decrease_days if decrease_days > 0 else float('inf')\n",
    "\n",
    "print(\"\\n========== SALES GROWTH ANALYSIS ==========\")\n",
    "print(f\"Days with Increased Sales : {increase_days} out of 29 ({(increase_days/29)*100:.2f}%)\")\n",
    "print(f\"Days with Decreased Sales : {decrease_days} out of 29 ({(decrease_days/29)*100:.2f}%)\")\n",
    "print(f\"Days with No Change       : {no_change_days} out of 29 ({(no_change_days/29)*100:.2f}%)\")\n",
    "print(f\"Average Growth (positive) : ₹{avg_growth:.2f}\")\n",
    "print(f\"Average Decline (negative): ₹{avg_decline:.2f}\")\n",
    "print(f\"Net Growth Trend          : ✅ POSITIVE ({growth_ratio:.2f}x more growth days)\")\n",
    "print(\"=\"*41)"
   ]
  },
  {
