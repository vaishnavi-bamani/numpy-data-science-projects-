    "## 🎯 Task 7: Sales Target Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "target-analysis",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "========== SALES TARGET ANALYSIS ==========\n",
      "Daily Target             : ₹3,000.00\n",
      "Days Achieved Target     : 16 out of 30 (53.33%)\n",
      "Days Missed Target       : 14 out of 30 (46.67%)\n",
      "Total Sales (Target Met) : ₹61,200.00\n",
      "Total Sales (Target Miss): ₹30,000.00\n",
      "Average (Target Met)     : ₹3,825.00\n",
      "Average (Target Miss)    : ₹2,142.86\n",
      "Revenue Loss (vs target) : ₹12,000.00 (estimated)\n",
      "=========================================\n"
     ]
    }
   ],
   "source": [
    "sales_target = 3000\n",
    "\n",
    "target_achieved_mask = sales >= sales_target\n",
    "target_missed_mask = sales < sales_target\n",
    "\n",
    "target_achieved_days = np.sum(target_achieved_mask)\n",
    "target_missed_days = np.sum(target_missed_mask)\n",
    "target_achieved_sales = sales[target_achieved_mask]\n",
    "target_missed_sales = sales[target_missed_mask]\n",
    "\n",
    "total_target_achieved = np.sum(target_achieved_sales)\n",
    "total_target_missed = np.sum(target_missed_sales)\n",
    "avg_target_achieved = np.mean(target_achieved_sales)\n",
    "avg_target_missed = np.mean(target_missed_sales)\n",
    "revenue_loss = (sales_target * target_missed_days) - total_target_missed\n",
    "\n",
    "print(\"\\n========== SALES TARGET ANALYSIS ==========\")\n",
    "print(f\"Daily Target             : ₹{sales_target:,.2f}\")\n",
    "print(f\"Days Achieved Target     : {target_achieved_days} out of 30 ({(target_achieved_days/30)*100:.2f}%)\")\n",
    "print(f\"Days Missed Target       : {target_missed_days} out of 30 ({(target_missed_days/30)*100:.2f}%)\")\n",
    "print(f\"Total Sales (Target Met) : ₹{total_target_achieved:,.2f}\")\n",
    "print(f\"Total Sales (Target Miss): ₹{total_target_missed:,.2f}\")\n",
    "print(f\"Average (Target Met)     : ₹{avg_target_achieved:,.2f}\")\n",
    "print(f\"Average (Target Miss)    : ₹{avg_target_missed:,.2f}\")\n",
    "print(f\"Revenue Loss (vs target) : ₹{revenue_loss:,.2f} (estimated)\")\n",
    "print(\"=\"*41)"
   ]
  },
