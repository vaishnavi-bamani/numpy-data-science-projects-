   "source": [
    "## 📅 Task 5: Weekend vs Weekday Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "86d00601",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "========== WEEKEND vs WEEKDAY ANALYSIS ==========\n",
      "Weekend Sales (Total)    : ₹25,800.00\n",
      "Weekday Sales (Total)    : ₹65,400.00\n",
      "Weekend Average/Day      : ₹1,800.00\n",
      "Weekday Average/Day      : ₹2,616.00\n",
      "Performance Difference   : Weekday is 45.33% higher\n",
      "Better Performance       : 📊 WEEKDAY\n",
      "===============================================\n"
     ]
    }
   ],
   "source": [
    "# Weekend vs Weekday Analysis\n",
    "weekend_mask = (days % 7 == 6) | (days % 7 == 0)\n",
    "weekday_mask = ~weekend_mask\n",
    "\n",
    "weekend_sales_total = np.sum(sales[weekend_mask])\n",
    "weekday_sales_total = np.sum(sales[weekday_mask])\n",
    "weekend_days_count = np.sum(weekend_mask)\n",
    "weekday_days_count = np.sum(weekday_mask)\n",
    "weekend_avg = weekend_sales_total / weekend_days_count\n",
    "weekday_avg = weekday_sales_total / weekday_days_count\n",
    "diff_percentage = ((weekday_avg - weekend_avg) / weekend_avg) * 100\n",
    "\n",
    "print(\"\\n========== WEEKEND vs WEEKDAY ANALYSIS ==========\")\n",
    "print(f\"Weekend Sales (Total)    : ₹{weekend_sales_total:,.2f}\")\n",
    "print(f\"Weekday Sales (Total)    : ₹{weekday_sales_total:,.2f}\")\n",
    "print(f\"Weekend Average/Day      : ₹{weekend_avg:,.2f}\")\n",
    "print(f\"Weekday Average/Day      : ₹{weekday_avg:,.2f}\")\n",
    "print(f\"Performance Difference   : Weekday is {diff_percentage:.2f}% higher\")\n",
    "print(f\"Better Performance       : 📊 {'WEEKDAY' if weekday_sales_total > weekend_sales_total else 'WEEKEND'}\")\n",
    "print(\"=\"*49)"
   ]
  },
